@using FirstMVCWebApp.Dto
@model UserDTO

<div class="container d-flex justify-content-center align-items-center vh-100">
    <div class="card p-4 shadow" style="width: 400px;">
        <h3 class="text-center mb-4">Create Account</h3>

        @* This shows errors from the Controller *@
        @if (ViewBag.Message != null)
        {
            <div class="alert alert-danger">@ViewBag.Message</div>
        }

        <form asp-action="Register" asp-controller="Auth" method="post">
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label class="form-label">Username</label>
                <input type="text" class="form-control" asp-for="UserName" placeholder="Enter username" required>
            </div>

            <div class="mb-3">
                <label class="form-label">Email</label>
                <input type="email" class="form-control" asp-for="Email" placeholder="Enter email" required>
            </div>

            <div class="mb-3">
                <label class="form-label">Password</label>
                <input type="password" class="form-control" asp-for="Password" placeholder="Create password" required>
            </div>

            <div class="d-grid">
                <button class="btn btn-success" type="submit">Register Now</button>
            </div>
        </form>

        <div class="mt-3 text-center">
            Already have an account? <a asp-action="Login" asp-controller="Auth">Login here</a>
        </div>
    </div>
</div>