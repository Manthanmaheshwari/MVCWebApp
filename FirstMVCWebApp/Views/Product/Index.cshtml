@model IEnumerable<FirstMVCWebApp.Models.Product>

@{
    ViewData["Title"] = "Product List";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-box-seam"></i> Product List</h2>
        <a asp-action="Create" asp-controller="Product" class="btn btn-success shadow-sm">
            + Add New Product
        </a>
    </div>

    <div class="card shadow">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Name</th>
                        <th>Description</th>
                        <th class="text-end">Price</th>
                        <th class="text-center">Stock</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-bold">@item.Name</td>
                                <td class="text-muted">@item.Description</td>
                                <td class="text-end">@item.Price.ToString("C")</td>
                                <td class="text-center">
                                    <span class="badge @(item.Stock > 0 ? "bg-info" : "bg-danger")">
                                        @item.Stock
                                    </span>
                                </td>
                                <td class="text-center">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-4 text-muted">No products found. Click "Add New Product" to start!</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>